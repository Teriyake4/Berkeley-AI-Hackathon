# Redis
# - Docker Compose: uses local redis://redis:6379 (REDIS_URL in .env is ignored by compose)
# - Manual / production: set Redis Cloud URL (often rediss:// for TLS, port 12278)
# - Leave blank for in-memory fallback (no persistence across restarts)
REDIS_URL=

# Deepgram (optional — Live mode falls back to Web Speech API)
DEEPGRAM_API_KEY=

# Anthropic (optional — primary LLM; uses heuristic fallbacks if unset)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
# NVIDIA NIM (optional — LLM fallback when Claude is unset or fails)
# Get a key at https://build.nvidia.com
NVIDIA_API_KEY=
# NIM_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Browserbase (optional — uses mock citations if unset)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Arize (optional)
ARIZE_SPACE_ID=
ARIZE_API_KEY=
